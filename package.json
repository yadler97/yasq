{
  "name": "yasq",
  "version": "1.3.0-dev",
  "private": true,
  "description": "A Multiplayer Soundtrack Quiz built as a Discord Activity.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yadler97/yasq.git"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "dev": "concurrently \"npm run dev:server\" \"wait-on http://localhost:3001/health && npm run dev:client\"",
    "dev:mock": "cross-env VITE_MOCK_MODE=true npm run dev",
    "test:unit": "npm run test -w server",
    "test:unit:coverage": "npm run test -w server -- --coverage",
    "test:integration": "cross-env VITE_MOCK_MODE=true vitest run tests/integration",
    "test:e2e": "cross-env VITE_MOCK_MODE=true UI_TEST_MODE=true playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:ui": "cross-env VITE_MOCK_MODE=true UI_TEST_MODE=true playwright test --config=tests/e2e/playwright.config.ts --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^10.0.3",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "discord-api-types": "^0.38.49"
  }
}
