{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./",             // Or "./src" if your code is in a src folder
    "outDir": "./dist",

    /* Environment Settings */
    "module": "NodeNext",        // Essential for modern Node.js ESM
    "moduleResolution": "NodeNext", 
    "target": "ESNext",
    "lib": ["ESNext"],           // Modern JS features
    "types": ["node"],           // Tells TS to look for @types/node

    /* Other Outputs */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Stricter Typechecking Options */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Recommended Options */
    "jsx": "react-jsx",          // Keep this if you have React, otherwise remove
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,        // Speeds up build by skipping type checks of node_modules
    "esModuleInterop": true      // Helps with importing older JS packages
  }
}
